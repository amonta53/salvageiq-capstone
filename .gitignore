# =========================================================
# SalvageIQ Capstone - Git Ignore Rules
# Purpose:
# Keep source code, tests, docs, and config in Git.
# Exclude runtime data, generated outputs, logs, debug files,
# local environments, and editor/cache clutter.
# =========================================================


# =========================================================
# Python runtime / build artifacts
# =========================================================
__pycache__/
*.py[cod]
*$py.class


# =========================================================
# Virtual environments
# =========================================================
.venv/
venv/
env/


# =========================================================
# Test / coverage / type-checker caches
# =========================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/


# =========================================================
# Editor / OS clutter
# =========================================================
.vscode/
.idea/
.DS_Store
Thumbs.db


# =========================================================
# Environment / local-only config
# =========================================================
.env
.env.*
*.local


# =========================================================
# Generated runtime data
# Entire run folders are created by the pipeline and should
# not be version controlled.
# =========================================================
# Ignore all runtime run data
data/runs/*

# Keep directory structure
!data/runs/.gitkeep

# Safety: ignore any nested content just in case
data/runs/*/*

# =========================================================
# Logs and debug output
# These are already under data/runs, but these rules also
# catch any top-level or stray log/debug files.
# =========================================================
logs/
*.log
ERROR_*.html


# =========================================================
# Archives / packaged outputs
# =========================================================
*.zip
*.7z
*.tar
*.gz


# =========================================================
# Jupyter notebooks checkpoints, if they ever show up
# =========================================================
.ipynb_checkpoints/